---
import BaseLayout from '../layouts/BaseLayout.astro';
import GameCard from '../components/GameCard.astro';
import { games } from '../data/games';
---

<BaseLayout
  title="Главная"
  description="MAD GAMES — инди-студия, создающая казуальные и инди-игры для браузера и мобайла"
>
  <!-- ══════════════════════════════════════════
       HERO
  ══════════════════════════════════════════ -->
  <div class="hero-scroll-wrapper">
  <section class="hero">
    <canvas class="hero-canvas" width="1280" height="720" aria-hidden="true"></canvas>
    <div class="hero-overlay" aria-hidden="true"></div>
    <div class="hero-floats" aria-hidden="true">
      <div class="fobj fobj-1" style="--r:-11deg" data-rotate="-11" data-depth="0.4"><div class="fobj-inner"><img src="/images/games/lava-escape/cover.jpg" alt="" /></div></div>
      <div class="fobj fobj-2" style="--r:8deg"  data-rotate="8"   data-depth="0.7"><div class="fobj-inner"><img src="/images/games/neon-jumper/cover.jpg" alt="" /></div></div>
      <div class="fobj fobj-3" style="--r:-6deg" data-rotate="-6"  data-depth="0.5"><div class="fobj-inner"><img src="/images/games/bubble-kingdom/cover.jpg" alt="" /></div></div>
      <div class="fobj fobj-4" style="--r:9deg"  data-rotate="9"   data-depth="0.6"><div class="fobj-inner"><img src="/images/games/star-raider/cover.jpg" alt="" /></div></div>
      <div class="fobj fobj-5" style="--r:-4deg" data-rotate="-4"  data-depth="0.3"><div class="fobj-inner"><img src="/images/games/steel-wheels/cover.jpg" alt="" /></div></div>
      <div class="fobj fobj-6" style="--r:7deg"  data-rotate="7"   data-depth="0.8"><div class="fobj-inner"><img src="/images/games/forest-spirits/cover.jpg" alt="" /></div></div>
    </div>

    <div class="hero-center">
      <span class="hero-eyebrow">■ MAD GAMES</span>
      <h1 class="hero-title">
        Создаём игры,<br />в&nbsp;которые<br />хочется играть
      </h1>
      <div class="hero-actions">
        <a href="/games" class="btn-hero">Наши игры ▾</a>
        <a href="/jobs" class="btn-hero btn-hero-ghost">Вакансии ▾</a>
      </div>
    </div>
  </section>
  </div>

  <!-- ══════════════════════════════════════════
       STATS
  ══════════════════════════════════════════ -->
  <section class="stats-section" aria-label="Показатели студии">
    <div class="stats-ticker">
      <div class="stats-track" id="statsTrack">
        <div class="stat"><span class="stat-num">6+</span><span class="stat-label">Игр выпущено</span></div>
        <span class="stat-sep" aria-hidden="true">✦</span>
        <div class="stat"><span class="stat-num">500K+</span><span class="stat-label">Игроков</span></div>
        <span class="stat-sep" aria-hidden="true">✦</span>
        <div class="stat"><span class="stat-num">3</span><span class="stat-label">Платформы</span></div>
        <span class="stat-sep" aria-hidden="true">✦</span>
        <div class="stat"><span class="stat-num">2020</span><span class="stat-label">Год основания</span></div>
        <span class="stat-sep" aria-hidden="true">✦</span>
        <div class="stat"><span class="stat-num">6+</span><span class="stat-label">Игр выпущено</span></div>
        <span class="stat-sep" aria-hidden="true">✦</span>
        <div class="stat"><span class="stat-num">500K+</span><span class="stat-label">Игроков</span></div>
        <span class="stat-sep" aria-hidden="true">✦</span>
        <div class="stat"><span class="stat-num">3</span><span class="stat-label">Платформы</span></div>
        <span class="stat-sep" aria-hidden="true">✦</span>
        <div class="stat"><span class="stat-num">2020</span><span class="stat-label">Год основания</span></div>
        <span class="stat-sep" aria-hidden="true">✦</span>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       ABOUT
  ══════════════════════════════════════════ -->
  <section class="about-section">
    <div class="about-inner">
      <div class="about-header reveal">
        <span class="about-eyebrow">■ О студии</span>
        <h2 class="about-title">Маленькая студия.<br />Большие игры.</h2>
      </div>

      <div class="about-cards-row">
        <div class="about-icard reveal">
          <div class="about-icard-img">
            <img src="/images/about/illus-1.png" alt="Геймплей прежде всего" loading="lazy" />
          </div>
          <div class="about-icard-body">
            <span class="icard-label">■ Геймплей</span>
            <h3 class="icard-title">Геймплей прежде всего</h3>
            <p class="icard-text">Мы начинаем с ощущений, а не с графики</p>
          </div>
        </div>

        <div class="about-icard reveal" style="--reveal-delay: 100ms">
          <div class="about-icard-img">
            <img src="/images/about/illus-2.png" alt="Авторский стиль" loading="lazy" />
          </div>
          <div class="about-icard-body">
            <span class="icard-label">■ Стиль</span>
            <h3 class="icard-title">Авторский стиль</h3>
            <p class="icard-text">Каждая игра узнаваема с первого взгляда</p>
          </div>
        </div>

        <div class="about-icard reveal" style="--reveal-delay: 200ms">
          <div class="about-icard-img">
            <img src="/images/about/illus-3.png" alt="Быстро и качественно" loading="lazy" />
          </div>
          <div class="about-icard-body">
            <span class="icard-label">■ Команда</span>
            <h3 class="icard-title">Быстро и качественно</h3>
            <p class="icard-text">Небольшая команда — меньше компромиссов</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       FEATURED GAMES
  ══════════════════════════════════════════ -->
  <section class="games-section">
    <video class="games-bg-video" autoplay muted loop playsinline poster="/images/games-section-bg.jpg">
      <source src="/videos/games-section-bg.mp4" type="video/mp4" />
    </video>
    <div class="games-overlay"></div>

    <div class="container games-content">
      <div class="section-header reveal">
        <span class="tag">Наши игры</span>
        <div class="section-title-row">
          <h2 class="section-title">Последние релизы</h2>
          <a href="/games" class="btn btn-outline">Все игры →</a>
        </div>
      </div>
    </div>

    <div class="games-slider-outer">
      <div class="games-slider" id="gamesSlider">
        <div class="games-track">
          {games.map((game) => (
            <div class="game-slide">
              <GameCard {...game} />
            </div>
          ))}
          {games.map((game) => (
            <div class="game-slide" aria-hidden="true">
              <GameCard {...game} />
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       JOIN CTA
  ══════════════════════════════════════════ -->
  <section class="join-section">
    <div class="join-floats" aria-hidden="true">
      <div class="jobj jobj-1" style="--r:-8deg" data-rotate="-8" data-depth="0.5">
        <div class="jobj-inner"><img src="/images/join-device-1.png" alt="" /></div>
      </div>
      <div class="jobj jobj-2" style="--r:12deg" data-rotate="12" data-depth="0.7">
        <div class="jobj-inner"><img src="/images/join-device-2.png" alt="" /></div>
      </div>
    </div>
    <div class="join-inner reveal">
      <span class="join-eyebrow">■ Команда</span>
      <h2 class="join-title">Присоединяйся<br />к команде</h2>
      <p class="join-desc">
        Ищем талантливых людей, которые любят игры так же, как и мы.
        Работаем удалённо, ценим инициативу и не делаем скучных вещей.
      </p>
      <div class="join-actions">
        <a href="/jobs" class="btn-join">Смотреть вакансии</a>
        <a href="mailto:Kurapov.99@yandex.ru" class="btn-join btn-join-ghost">Написать нам</a>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // ── Hero cards: ambient drift + 3D cursor follow ──
  const hero = document.querySelector('.hero') as HTMLElement | null;
  const fobjCards = document.querySelectorAll<HTMLElement>('.fobj');

  if (hero && fobjCards.length) {
    let targetDx = 0, targetDy = 0;
    let currentDx = 0, currentDy = 0;
    let mouseInside = false;
    let driftTime = 0;

    const driftParams = Array.from(fobjCards).map((_, i) => ({
      phase:  i * (Math.PI * 2 / fobjCards.length),
      freqX:  0.50 + i * 0.08,
      freqY:  0.40 + i * 0.06,
    }));

    hero.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = hero.getBoundingClientRect();
      targetDx = (e.clientX - rect.left - rect.width  / 2) / (rect.width  / 2);
      targetDy = (e.clientY - rect.top  - rect.height / 2) / (rect.height / 2);
      mouseInside = true;
    });

    hero.addEventListener('mouseleave', () => {
      mouseInside = false;
      targetDx = 0;
      targetDy = 0;
    });

    (function loop() {
      driftTime += 0.01;

      const lerpK = mouseInside ? 0.08 : 0.05;
      currentDx += (targetDx - currentDx) * lerpK;
      currentDy += (targetDy - currentDy) * lerpK;

      fobjCards.forEach((card, i) => {
        const depth  = parseFloat(card.dataset.depth  || '0.5');
        const rotate = parseFloat(card.dataset.rotate || '0');
        const dp = driftParams[i];

        const driftX = Math.sin(driftTime * dp.freqX + dp.phase) * 40;
        const driftY = Math.cos(driftTime * dp.freqY + dp.phase * 1.3) * 40;

        const tx   = currentDx * 60 * depth + driftX;
        const ty   = currentDy * 40 * depth + driftY;
        const ry   =  currentDx * 36 * depth;
        const rx   = -currentDy * 24 * depth;
        const tilt =  currentDx *  4 * depth;

        card.style.transform = `perspective(700px) rotateY(${ry}deg) rotateX(${rx}deg) rotate(${rotate + tilt}deg) translate(${tx}px, ${ty}px)`;
      });

      requestAnimationFrame(loop);
    })();
  }

  // ── Hero canvas: image-sequence scroll animation ──
  const heroCanvas = document.querySelector('.hero-canvas') as HTMLCanvasElement | null;
  const heroWrapper = document.querySelector('.hero-scroll-wrapper') as HTMLElement | null;
  if (heroCanvas && heroWrapper) {
    const ctx = heroCanvas.getContext('2d');
    const TOTAL = 145;
    const frames: HTMLImageElement[] = [];

    // Preload all frames
    for (let i = 0; i < TOTAL; i++) {
      const img = new Image();
      img.src = `/images/hero-frames/frame-${String(i + 1).padStart(3, '0')}.jpg`;
      frames.push(img);
    }

    let currentF = 0;
    let targetF  = 0;

    const draw = (f: number) => {
      const img = frames[Math.round(Math.min(Math.max(f, 0), TOTAL - 1))];
      if (img?.complete && ctx) {
        ctx.drawImage(img, 0, 0, heroCanvas.width, heroCanvas.height);
      }
    };

    // RAF loop: lerp toward target frame
    (function loop() {
      requestAnimationFrame(loop);
      currentF += (targetF - currentF) * 0.35;
      draw(currentF);
    })();

    // Update target on scroll
    window.addEventListener('scroll', () => {
      const range = heroWrapper.offsetHeight - window.innerHeight;
      const progress = Math.min(Math.max(window.scrollY / range, 0), 1);
      targetF = progress * (TOTAL - 1);
    }, { passive: true });

    // Draw first frame as soon as it loads
    frames[0].onload = () => draw(0);
  }

  // ── About cards: 3D tilt on hover ──
  document.querySelectorAll<HTMLElement>('.about-icard').forEach(card => {
    card.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = card.getBoundingClientRect();
      const dx = (e.clientX - rect.left - rect.width  / 2) / (rect.width  / 2);
      const dy = (e.clientY - rect.top  - rect.height / 2) / (rect.height / 2);
      const ry =  dx * 14;
      const rx = -dy * 10;
      card.style.transition = 'transform 0.08s ease-out';
      card.style.transform = `perspective(800px) rotateY(${ry}deg) rotateX(${rx}deg)`;
    });

    card.addEventListener('mouseleave', () => {
      card.style.transition = 'transform 0.5s ease-out';
      card.style.transform = 'perspective(800px) rotateY(0deg) rotateX(0deg)';
    });
  });

  // ── Games slider: 3D tilt on card hover ──
  document.querySelectorAll<HTMLElement>('.game-slide').forEach(slide => {
    slide.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = slide.getBoundingClientRect();
      const dx = (e.clientX - rect.left - rect.width  / 2) / (rect.width  / 2);
      const dy = (e.clientY - rect.top  - rect.height / 2) / (rect.height / 2);
      const ry =  dx * 14;
      const rx = -dy * 10;
      slide.style.transition = 'transform 0.08s ease-out';
      slide.style.transform = `perspective(800px) rotateY(${ry}deg) rotateX(${rx}deg)`;
    });

    slide.addEventListener('mouseleave', () => {
      slide.style.transition = 'transform 0.5s ease-out';
      slide.style.transform = 'perspective(800px) rotateY(0deg) rotateX(0deg)';
    });
  });

  // ── Join section devices: ambient drift + 3D cursor follow ──
  const joinSection = document.querySelector('.join-section') as HTMLElement | null;
  const jobjCards = document.querySelectorAll<HTMLElement>('.jobj');

  if (joinSection && jobjCards.length) {
    let jTargetDx = 0, jTargetDy = 0;
    let jCurrentDx = 0, jCurrentDy = 0;
    let jMouseInside = false;
    let jDriftTime = 0;

    const jDriftParams = Array.from(jobjCards).map((_, i) => ({
      phase:  i * (Math.PI * 2 / jobjCards.length) + 1.2,
      freqX:  0.42 + i * 0.11,
      freqY:  0.33 + i * 0.09,
    }));

    joinSection.addEventListener('mousemove', (e: MouseEvent) => {
      const rect = joinSection.getBoundingClientRect();
      jTargetDx = (e.clientX - rect.left - rect.width  / 2) / (rect.width  / 2);
      jTargetDy = (e.clientY - rect.top  - rect.height / 2) / (rect.height / 2);
      jMouseInside = true;
    });

    joinSection.addEventListener('mouseleave', () => {
      jMouseInside = false;
      jTargetDx = 0;
      jTargetDy = 0;
    });

    (function joinLoop() {
      jDriftTime += 0.01;

      const lerpK = jMouseInside ? 0.08 : 0.05;
      jCurrentDx += (jTargetDx - jCurrentDx) * lerpK;
      jCurrentDy += (jTargetDy - jCurrentDy) * lerpK;

      jobjCards.forEach((card, i) => {
        const depth  = parseFloat(card.dataset.depth  || '0.5');
        const rotate = parseFloat(card.dataset.rotate || '0');
        const dp = jDriftParams[i];

        const driftX = Math.sin(jDriftTime * dp.freqX + dp.phase) * 30;
        const driftY = Math.cos(jDriftTime * dp.freqY + dp.phase * 1.3) * 30;

        const tx   = jCurrentDx * 50 * depth + driftX;
        const ty   = jCurrentDy * 35 * depth + driftY;
        const ry   =  jCurrentDx * 28 * depth;
        const rx   = -jCurrentDy * 18 * depth;
        const tilt =  jCurrentDx *  3 * depth;

        card.style.transform = `perspective(700px) rotateY(${ry}deg) rotateX(${rx}deg) rotate(${rotate + tilt}deg) translate(${tx}px, ${ty}px)`;
      });

      requestAnimationFrame(joinLoop);
    })();
  }

  // ── Scroll-driven ticker ──
  const track = document.getElementById('statsTrack') as HTMLElement | null;

  if (track) {
    let lastScroll = 0;
    let offset = 0;
    const isMobile = window.matchMedia('(max-width: 768px)').matches;
    const speed = isMobile ? 0.6 : 0.25;

    window.addEventListener('scroll', () => {
      const scrollY = window.scrollY;
      const delta = scrollY - lastScroll;
      lastScroll = scrollY;
      offset += delta * speed;

      const halfWidth = track.scrollWidth / 2;
      if (offset > halfWidth) offset -= halfWidth;
      if (offset < 0)         offset += halfWidth;

      track.style.transform = `translateX(-${offset}px)`;
    }, { passive: true });
  }
</script>

<style>
  /* ── HERO ── */
  .hero-scroll-wrapper {
    height: 167vh;
  }

  .hero {
    position: sticky;
    top: 0;
    height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    background: #000;
  }

  .hero-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 16, 0.62);
    z-index: 0;
  }

  .hero-floats {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }

  .fobj {
    position: absolute;
    border-radius: 10px;
    overflow: hidden;
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.8);
    transform: rotate(var(--r, 0deg));
    will-change: transform;
    transition: none;
    aspect-ratio: 8 / 5;
  }

  .fobj-inner {
    width: 100%;
    height: 100%;
  }

  .fobj img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* widths calibrated to 2560px viewport (2K reference) */
  .fobj-1 { width: 16.4vw; top: 5%;     left: 6%;   }
  .fobj-2 { width: 14.1vw; top: 5%;     right: 6%;  }
  .fobj-3 { width: 15.6vw; top: 35%;    right: 4%;  }
  .fobj-4 { width: 12.9vw; bottom: 12%; left: 6%;   }
  .fobj-5 { width: 16.0vw; bottom: 5%;  right: 6%;  }
  .fobj-6 { width: 13.7vw; bottom: 5%;  left: 22%;  }

  .hero-center {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 36px;
    padding: 100px 24px 80px;
    max-width: 900px;
  }

  .hero-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(240, 240, 248, 0.4);
  }

  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(52px, 9vw, 120px);
    font-weight: 900;
    line-height: 0.93;
    letter-spacing: -0.02em;
    color: var(--color-text);
    text-transform: uppercase;
  }

  .hero-actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .btn-hero {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 20px;
    border: 1.5px solid rgba(240, 240, 248, 0.3);
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text);
    background: transparent;
    transition: border-color 0.25s, background 0.25s;
    cursor: pointer;
    text-decoration: none;
  }

  .btn-hero:hover {
    border-color: rgba(240, 240, 248, 0.7);
    background: rgba(240, 240, 248, 0.06);
  }

  .btn-hero-ghost {
    border-color: rgba(240, 240, 248, 0.12);
    color: rgba(240, 240, 248, 0.5);
  }

  .btn-hero-ghost:hover {
    border-color: rgba(240, 240, 248, 0.4);
    color: var(--color-text);
    background: transparent;
  }

  /* ── STATS TICKER ── */
  .stats-section {
    padding: 48px 0;
    margin-top: 200px;
    margin-bottom: 144px;
    overflow: hidden;
  }

  .stats-ticker {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
  }

  .stats-track {
    display: flex;
    align-items: flex-start;
    gap: 64px;
    width: max-content;
    will-change: transform;
  }

  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(80px, 10vw, 140px);
    font-weight: 900;
    color: var(--color-text);
    line-height: 1;
    white-space: nowrap;
  }

  .stat-label {
    font-size: clamp(11px, 1.2vw, 15px);
    color: var(--color-text-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .stat-sep {
    font-size: 28px;
    color: var(--color-accent);
    flex-shrink: 0;
    opacity: 0.5;
    align-self: center;
    margin-top: -16px;
  }

  /* ── ABOUT ── */
  .about-section {
    background: #E83455;
    padding: 96px 0;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .about-inner {
    width: 100%;
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    flex-direction: column;
    gap: 52px;
  }

  .about-header {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .about-eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.45);
  }

  .about-title {
    font-size: clamp(36px, 5.5vw, 72px);
    font-weight: 900;
    line-height: 1.0;
    text-transform: uppercase;
    color: #000;
  }

  .about-cards-row {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .about-icard {
    background: #0a0a10;
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .about-icard-img {
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .about-icard-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .about-icard:hover .about-icard-img img {
    transform: scale(1.04);
  }

