---
import BaseLayout from '../layouts/BaseLayout.astro';
import JobCard from '../components/JobCard.astro';
import { jobs } from '../data/jobs';
---

<BaseLayout
  title="Вакансии"
  description="Открытые вакансии студии MAD GAMES — присоединяйся к команде"
>
  <!-- ══════════════════════════════════════════
       FIXED BG: stays pinned to viewport until
       purple sections scroll over and cover it
  ══════════════════════════════════════════ -->
  <div class="jobs-hero-bg" aria-hidden="true">
    <img src="/images/jobs-hero.png" alt="" class="jobs-hero-img" />
    <div class="jobs-hero-overlay"></div>
  </div>

  <!-- ══════════════════════════════════════════
       HERO: 100vh, centered text over fixed bg
  ══════════════════════════════════════════ -->
  <section class="jobs-hero">
    <div class="jobs-hero-content">
      <span class="jobs-eyebrow">■ Команда</span>
      <h1 class="jobs-title">Вакансии</h1>
      <p class="jobs-desc">
        Ищем талантливых людей, которые любят игры. Работаем удалённо,
        двигаемся быстро и делаем вещи с душой.
      </p>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       WHY MAD GAMES: scroll-driven perks ticker
       dark gradient bg — fixed image shows through
  ══════════════════════════════════════════ -->
  <section class="why-section">
    <div class="perks-ticker">
      <div class="perks-track" id="perksTrack">
        <!-- Set 1 -->
        <div class="perk-item">
          <div class="perk-icon-wrap" aria-hidden="true">🌍</div>
          <div class="perk-info">
            <h4>Полная удалёнка</h4>
            <p>Работай откуда угодно. Главное — результат</p>
          </div>
        </div>
        <span class="perk-sep" aria-hidden="true">✦</span>
        <div class="perk-item">
          <div class="perk-icon-wrap" aria-hidden="true">🚀</div>
          <div class="perk-info">
            <h4>Быстрый рост</h4>
            <p>Небольшая команда = быстрые решения и реальное влияние</p>
          </div>
        </div>
        <span class="perk-sep" aria-hidden="true">✦</span>
        <div class="perk-item">
          <div class="perk-icon-wrap" aria-hidden="true">🎯</div>
          <div class="perk-info">
            <h4>Реальные проекты</h4>
            <p>Твоя работа выходит в релиз и играется сотнями тысяч людей</p>
          </div>
        </div>
        <span class="perk-sep" aria-hidden="true">✦</span>
        <div class="perk-item">
          <div class="perk-icon-wrap" aria-hidden="true">🤝</div>
          <div class="perk-info">
            <h4>Честная атмосфера</h4>
            <p>Без бюрократии, с уважением и прямым фидбеком</p>
          </div>
        </div>
        <span class="perk-sep" aria-hidden="true">✦</span>
        <!-- Set 2 – duplicate for seamless loop -->
        <div class="perk-item" aria-hidden="true">
          <div class="perk-icon-wrap">🌍</div>
          <div class="perk-info">
            <h4>Полная удалёнка</h4>
            <p>Работай откуда угодно. Главное — результат</p>
          </div>
        </div>
        <span class="perk-sep" aria-hidden="true">✦</span>
        <div class="perk-item" aria-hidden="true">
          <div class="perk-icon-wrap">🚀</div>
          <div class="perk-info">
            <h4>Быстрый рост</h4>
            <p>Небольшая команда = быстрые решения и реальное влияние</p>
          </div>
        </div>
        <span class="perk-sep" aria-hidden="true">✦</span>
        <div class="perk-item" aria-hidden="true">
          <div class="perk-icon-wrap">🎯</div>
          <div class="perk-info">
            <h4>Реальные проекты</h4>
            <p>Твоя работа выходит в релиз и играется сотнями тысяч людей</p>
          </div>
        </div>
        <span class="perk-sep" aria-hidden="true">✦</span>
        <div class="perk-item" aria-hidden="true">
          <div class="perk-icon-wrap">🤝</div>
          <div class="perk-info">
            <h4>Честная атмосфера</h4>
            <p>Без бюрократии, с уважением и прямым фидбеком</p>
          </div>
        </div>
        <span class="perk-sep" aria-hidden="true">✦</span>
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       JOB LISTINGS — purple bg, white cards
       (opaque bg covers the fixed hero image)
  ══════════════════════════════════════════ -->
  <section class="jobs-section">
    <div class="container">
      <div class="jobs-header reveal">
        <h2 class="jobs-section-title">Открытые позиции</h2>
        <span class="jobs-badge">{jobs.length} вакансии</span>
      </div>

      <div class="jobs-list">
        {jobs.map((job, i) => (
          <div class="reveal" style={`--reveal-delay: ${i * 80}ms`}>
            <JobCard {...job} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ══════════════════════════════════════════
       APPLICATION FORM
  ══════════════════════════════════════════ -->
  <section class="apply-section" id="apply">
    <div class="container">
      <div class="apply-card reveal">
        <div class="apply-info">
          <span class="apply-eyebrow">■ Отклик</span>
          <h2 class="apply-title">Хочешь к нам?</h2>
          <p class="apply-desc">
            Заполни форму — ответим в течение 2–3 рабочих дней. Или напиши
            напрямую:&nbsp;
            <a href="mailto:Kurapov.99@yandex.ru">Kurapov.99@yandex.ru</a>
          </p>
          <div class="apply-note">
            <span class="apply-note-icon" aria-hidden="true">💡</span>
            Даже если подходящей вакансии нет — пиши. Рассматриваем сильных
            специалистов в любое время.
          </div>
        </div>

        <form
          class="apply-form"
          action={`mailto:Kurapov.99@yandex.ru`}
          method="POST"
          enctype="text/plain"
          id="apply-form"
        >
          <div class="form-row">
            <div class="form-group">
              <label for="name" class="form-label">Имя *</label>
              <input
                type="text"
                id="name"
                name="Имя"
                required
                class="form-input"
                placeholder="Иван Иванов"
                autocomplete="name"
              />
            </div>
            <div class="form-group">
              <label for="position" class="form-label">Желаемая должность *</label>
              <input
                type="text"
                id="position"
                name="Должность"
                required
                class="form-input"
                placeholder="2D Художник"
              />
            </div>
          </div>

          <div class="form-group">
            <label for="portfolio" class="form-label">Ссылка на портфолио / резюме *</label>
            <input
              type="url"
              id="portfolio"
              name="Портфолио"
              required
              class="form-input"
              placeholder="https://..."
            />
          </div>

          <div class="form-group">
            <label for="message" class="form-label">Сообщение</label>
            <textarea
              id="message"
              name="Сообщение"
              class="form-textarea"
              rows="4"
              placeholder="Расскажи немного о себе и своём опыте"
            ></textarea>
          </div>

          <button type="submit" class="btn btn-primary form-submit">
            Отправить отклик →
          </button>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Force header into scrolled state (dark backdrop) from the start
  document.getElementById('site-header')?.classList.add('always-scrolled');

  // Fix footer stacking: the fixed hero-bg (z-index:0) paints above non-positioned elements
  document.querySelector('.footer')?.classList.add('jobs-page-footer');

</script>

<style>
  /* ══ FIXED BACKGROUND IMAGE ══
     Pinned behind hero + why sections.
     Purple jobs/apply sections are opaque and cover it on scroll.
  */
  .jobs-hero-bg {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100vh;
    z-index: 0;
    pointer-events: none;
  }

  .jobs-hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .jobs-hero-overlay {
    position: absolute;
    inset: 0;
    background: rgba(10, 10, 16, 0.62);
  }

  /* ══ HERO ══ */
  .jobs-hero {
    position: relative;
    z-index: 1;
    height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .jobs-hero-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    padding: 0 24px;
    max-width: 820px;
  }

  .jobs-eyebrow {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(240, 240, 248, 0.4);
  }

  .jobs-title {
    font-family: var(--font-display);
    font-size: clamp(52px, 9vw, 120px);
    font-weight: 900;
    line-height: 0.93;
    letter-spacing: -0.02em;
    color: var(--color-text);
    text-transform: uppercase;
  }

  .jobs-desc {
    font-size: 16px;
    color: rgba(240, 240, 248, 0.58);
    max-width: 520px;
    line-height: 1.75;
  }

  /* ══ WHY SECTION ══ */
  .why-section {
    position: relative;
    z-index: 1;
    padding: 160px 0;
    display: flex;
    align-items: center;
    /* Gradient: transparent at top so fixed image bleeds in, dark at bottom */
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(10, 10, 16, 0.47) 20%,
      rgba(10, 10, 16, 0.47) 100%
    );
  }

  /* Perks ticker */
  .perks-ticker {
    overflow: hidden;
    mask-image: linear-gradient(90deg, transparent 0%, black 6%, black 94%, transparent 100%);
  }

  @keyframes perks-loop {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  .perks-track {
    display: flex;
    align-items: center;
    gap: 48px;
    width: max-content;
    animation: perks-loop 28s linear infinite;
  }

  .perk-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .perk-icon-wrap {
    display: none;
  }

  .perk-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 24px;
  }

  .perk-info h4 {
    font-family: var(--font-display);
    font-size: clamp(36px, 4.5vw, 72px);
    font-weight: 900;
    color: var(--color-text);
    line-height: 1;
    white-space: nowrap;
    margin-bottom: 0;
  }

  .perk-info p {
    font-size: clamp(11px, 1.2vw, 15px);
    color: var(--color-text);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    white-space: nowrap;
    line-height: 1;
    max-width: none;
  }

  .perk-sep {
    font-size: 28px;
    color: var(--color-accent);
    opacity: 0.5;
    flex-shrink: 0;
    align-self: center;
    margin-top: -16px;
  }

  /* ══ JOBS SECTION — purple, covers fixed bg ══ */
  .jobs-section {
    position: relative;
    z-index: 2;
    background: #AE80EE;
    padding: 96px 0 80px;
  }

  .jobs-header {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 28px;
  }

  .jobs-section-title {
    font-size: clamp(22px, 2.8vw, 34px);
    font-weight: 900;
    color: #000;
  }

  .jobs-badge {
    font-size: 14px;
    font-weight: 400;
    color: rgba(0, 0, 0, 0.5);
  }

  .jobs-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  /* White card overrides — JobCard on purple bg */
  :global(.jobs-section .job-card) {
    background: #fff;
    border-color: rgba(0, 0, 0, 0.08);
  }

  :global(.jobs-section .job-card:hover) {
    border-color: rgba(232, 52, 85, 0.3);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.15);
    transform: translateY(-2px);
  }

  :global(.jobs-section .job-title) {
    color: #0a0a10;
  }

  :global(.jobs-section .job-type) {
    background: #E83455;
    color: #fff;
  }

  :global(.jobs-section .job-desc) {
    color: rgba(10, 10, 16, 0.6);
  }

  :global(.jobs-section .tech-tag) {
    background: rgba(10, 10, 16, 0.06);
    color: rgba(10, 10, 16, 0.55);
    border-color: rgba(10, 10, 16, 0.1);
  }

  :global(.jobs-section .apply-btn:hover) {
    box-shadow: none;
  }

  /* ══ APPLY SECTION — also covers fixed bg ══ */
  .apply-section {
    position: relative;
    z-index: 2;
    background: #fff;
    padding: 96px 0;
  }

  .apply-card {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: 64px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .apply-eyebrow {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.45);
    margin-bottom: 20px;
  }

  .apply-title {
    font-size: clamp(24px, 3vw, 42px);
    font-weight: 900;
    margin-bottom: 16px;
    color: #000;
  }

  .apply-desc {
    font-size: 14px;
    color: rgba(0, 0, 0, 0.65);
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .apply-desc a {
    color: #1a0030;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .apply-note {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    background: rgba(0, 0, 0, 0.08);
    border-radius: var(--radius-sm);
    padding: 14px 16px;
    font-size: 13px;
    color: rgba(0, 0, 0, 0.65);
    line-height: 1.55;
    border: 1px solid rgba(0, 0, 0, 0.1);
  }

  .apply-note-icon {
    font-size: 16px;
    flex-shrink: 0;
    line-height: 1.4;
  }

  .apply-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-label {
    font-size: 13px;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.7);
    letter-spacing: 0.02em;
  }

  .form-input,
  .form-textarea {
    background: rgba(0, 0, 0, 0.1);
    border: 1.5px solid rgba(0, 0, 0, 0.2);
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    font-family: var(--font-body);
    font-size: 15px;
    color: #1a0030;
    transition: border-color 0.2s ease, background 0.2s ease;
    width: 100%;
    resize: vertical;
  }

  .form-input::placeholder,
  .form-textarea::placeholder {
    color: rgba(26, 0, 48, 0.4);
  }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: rgba(0, 0, 0, 0.5);
    background: rgba(0, 0, 0, 0.15);
  }

  .form-submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 10px 24px;
    border: 1.5px solid transparent;
    border-radius: 4px;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    background: #0a0a10;
    transition: background 0.2s;
    cursor: pointer;
  }

  .form-submit:hover {
    background: #1e1e2e;
    border-color: transparent;
    box-shadow: none;
  }

  /* Footer fix: give it a stacking context so fixed bg can't bleed through */
  :global(.footer.jobs-page-footer) {
    position: relative;
    z-index: 2;
  }

  /* always-scrolled header override for this page */
  :global(.header.always-scrolled) {
    background: rgba(10, 10, 16, 0.92);
    backdrop-filter: blur(16px);
    border-bottom: 1px solid rgba(240, 240, 248, 0.06);
  }

  /* ══ RESPONSIVE ══ */
  @media (max-width: 1024px) {
    .apply-card {
      grid-template-columns: 1fr;
      gap: 40px;
    }
  }

  @media (max-width: 768px) {
    .perk-item {
      min-width: 250px;
      padding: 20px 22px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }

    .apply-card {
      padding: 0 20px;
    }

    .form-submit {
      width: 100%;
      justify-content: center;
    }
  }
</style>
