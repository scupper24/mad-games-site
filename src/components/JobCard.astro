---
interface Props {
  id: string;
  title: string;
  type: string;
  description: string;
  stack?: string[];
}

const { id, title, type, description, stack = [] } = Astro.props;
---

<article class="job-card" id={id}>
  <div class="job-header">
    <div class="job-info">
      <h3 class="job-title">{title}</h3>
      <span class="job-type">{type}</span>
    </div>
    <a
      href={`mailto:Kurapov.99@yandex.ru?subject=Отклик на вакансию: ${encodeURIComponent(title)}`}
      class="btn btn-primary apply-btn"
      aria-label={`Откликнуться на вакансию ${title}`}
    >
      Откликнуться
    </a>
  </div>

  <p class="job-desc">{description}</p>

  {stack.length > 0 && (
    <div class="job-stack" aria-label="Стек технологий">
      {stack.map(tech => (
        <span class="tech-tag">{tech}</span>
      ))}
    </div>
  )}
</article>

<style>
  .job-card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    padding: 32px;
    border: 1px solid rgba(240, 240, 248, 0.06);
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  .job-card:hover {
    border-color: rgba(232, 52, 85, 0.25);
    transform: translateY(-2px);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
  }

  .job-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 16px;
  }

  .job-title {
    font-size: 20px;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 8px;
  }

  .job-type {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--color-accent-2);
    background: rgba(255, 140, 32, 0.1);
    padding: 4px 12px;
    border-radius: 100px;
  }

  .apply-btn {
    flex-shrink: 0;
    padding: 10px 22px;
    font-size: 13px;
  }

  .job-desc {
    font-size: 14px;
    color: rgba(240, 240, 248, 0.6);
    line-height: 1.7;
    margin-bottom: 20px;
  }

  .job-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  .tech-tag {
    font-size: 12px;
    font-weight: 500;
    padding: 5px 12px;
    background: rgba(240, 240, 248, 0.05);
    border-radius: 100px;
    color: var(--color-text-muted);
    border: 1px solid rgba(240, 240, 248, 0.08);
  }

  @media (max-width: 600px) {
    .job-header {
      flex-direction: column;
    }

    .job-card {
      padding: 24px;
    }

    .apply-btn {
      width: 100%;
      justify-content: center;
    }
  }
</style>
